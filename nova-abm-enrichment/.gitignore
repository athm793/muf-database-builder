.venv/
venv/
__pycache__/
*.pyc
*.pyo
.DS_Store
.env

# Bulk caches: multi-GB, exceed GitHub limits — re-download via scripts
states/*/bulk/*
!states/*/bulk/.gitkeep

# Debug artifacts: screenshots + HTML from failed scrapes, ephemeral
states/*/debug/*
!states/*/debug/.gitkeep

# Per-entity drawer text dumps: large, can re-derive from bulk CSV
states/*/output/drawer_text/

# Legacy locations from pre-restructure (should be empty)
data/output/*
data/input/*

# Legacy debug dirs (pre-restructure)
bizfile_debug/
sunbiz_debug/
texas_debug/

# IDE
.vscode/
.idea/
