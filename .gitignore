# Python
__pycache__/
*.pyc
*.pyo
.DS_Store
.env

# Virtual environments (per-project, can be regenerated)
.venv/
venv/

# Source FDD PDFs — large binaries. The per-PDF extraction caches under
# FDD Parser/Code/cache/ are the durable artifact, so the PDFs themselves
# don't need to live in the repo (keeps employee pushes small and fast).
FDD Parser/Data/**/*.pdf
FDD Parser/Data/*.pdf

# Pipeline run logs — regenerated every run, no need to track.
FDD Parser/Code/*.log

# Bulk dataset caches — multi-GB downloads, exceed GitHub file limits
# Regenerate by running the enrich scripts (they auto-download/refresh).
states/*/bulk/
**/bulk/cordata*.zip
**/bulk/cordata*.txt
**/bulk/active_corps.csv
**/bulk/business_entities.csv
**/bulk/*.log

# Debug artifacts from failed scrape attempts (screenshots, HTML dumps)
states/*/debug/
*/debug/

# Per-entity drawer text dumps (CA scrape; large, can re-derive)
states/*/output/drawer_text/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db
desktop.ini
